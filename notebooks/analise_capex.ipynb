import pandas as pd

# Ler arquivos CSV
projetos = pd.read_csv('data/projetos.csv')
movimentacoes = pd.read_csv('data/movimentacoes.csv')

# Mostrar tabelas
print("Projetos:")
print(projetos)
print("\nMovimentações:")
print(movimentacoes)

# Calcular total gasto por projeto
total_gasto = movimentacoes.groupby('projeto')['valor'].sum()

# Unir com projetos e calcular desvio
resultado = projetos.set_index('id_projeto').join(total_gasto.rename('gasto_real'))
resultado['desvio'] = resultado['orcamento_aprovado'] - resultado['gasto_real']

print("\nResultado final:")
print(resultado)